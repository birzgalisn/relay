{
  "name": "relay",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "db:migrate": "turbo run db:migrate --filter=@repo/prisma",
    "db:check": "turbo run db:check --filter=@repo/prisma",
    "db:deploy": "turbo run db:deploy --filter=@repo/prisma",
    "db:seed": "turbo run db:seed --filter=@repo/prisma",
    "db:sync": "pnpm run db:deploy && pnpm run db:seed",
    "db:prepare": "turbo run db:prepare --filter=@repo/prisma"
  },
  "devDependencies": {
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint-plugin-turbo": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
