{
  "name": "@repo/codegen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "graphql-codegen --config ./codegen.config.ts",
    "dev": "pnpm run generate -- --watch",
    "check-types": "tsc --noEmit",
    "lint": "oxlint .",
    "clean": "rm -rf .turbo node_modules tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/near-operation-file-preset": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@graphql-codegen/typed-document-node": "catalog:",
    "@graphql-codegen/typescript-operations": "catalog:",
    "@parcel/watcher": "catalog:",
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "graphql": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
