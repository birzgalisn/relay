{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "./dist/**"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "clean": "rm -r .turbo dist node_modules",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@nestjs/mapped-types": "catalog:"
  },
  "devDependencies": {
    "@repo/oxlint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "ts-node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
