generator client {
  provider = "prisma-client"
  output   = "../src/_generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id          String   @id @default(uuid())
  title       String
  url         String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
