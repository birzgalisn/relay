{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "nest start --watch",
    "dev:debug": "nest start --debug --watch",
    "build": "tsdown && node dist/write-graphql-schema.js && pnpm exec oxfmt src/_generated/schema.graphql",
    "clean": "rm -rf dist node_modules tsconfig.tsbuildinfo",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@apollo/server": "catalog:",
    "@as-integrations/fastify": "catalog:",
    "@nestjs/apollo": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/graphql": "catalog:",
    "@nestjs/platform-fastify": "catalog:",
    "@repo/prisma": "workspace:*",
    "fastify": "catalog:",
    "graphql": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@jest/globals": "catalog:",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@nestjs/cli": "catalog:",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@repo/oxlint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "jest": "catalog:",
    "source-map-support": "catalog:",
    "ts-jest": "catalog:",
    "ts-loader": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
